// ============================================================================
// MCG Student Services Portal — Prisma schema
// Single canonical schema; all modules share this. Do not edit shipped
// migrations; create a new migration for every change.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------

enum SisSource {
  campuslogin
  salesforce
}

enum StudentStatus {
  start
  stay
  at_risk
  withdrawn
  on_practicum
  graduated
  re_entry
  alumni
}

enum UserRole {
  rep
  coordinator
  manager
  admin
  auditor
  student
  counselor
  tutor
}

enum CommunicationDirection {
  inbound
  outbound
}

enum CommunicationChannel {
  email
  sms
  call
  voicemail
}

enum TaskPriority {
  low
  normal
  high
  urgent
}

enum TaskStatus {
  open
  in_progress
  blocked
  done
  cancelled
}

enum CaseStatus {
  open
  in_progress
  escalated
  closed
}

enum InterventionType {
  academic
  attendance
  personal
}

enum InterventionStatus {
  assigned
  in_progress
  completed
  abandoned
}

enum AccommodationStatus {
  requested
  approved
  rejected
  active
  expired
}

enum AttendanceSource {
  bbb
  manual
}

enum NewsletterStatus {
  scheduled
  sent
  failed
}

enum ReentryStatus {
  active
  completed
  abandoned
}

enum PracticumStatus {
  pending
  active
  completed
  failed
}

enum AppointmentKind {
  advising
  counseling
  tutoring
  career
  other
}

enum AppointmentStatus {
  requested
  confirmed
  in_progress
  completed
  cancelled
  no_show
}

enum AppointmentLocation {
  in_person
  video
  phone
}

enum DocumentKind {
  id
  transcript
  accommodation
  enrollment_agreement
  reentry_doc
  other
}

enum DocumentStatus {
  uploaded
  under_review
  approved
  rejected
  expired
}

enum MessageThreadStatus {
  open
  resolved
  archived
}

enum WellnessRiskTier {
  none
  low
  moderate
  high
  crisis
}

enum AnonymousReportCategory {
  harassment
  discrimination
  mental_health
  safety
  academic_integrity
  other
}

enum AnonymousReportStatus {
  new
  triaged
  in_progress
  resolved
  closed_no_action
}

enum ResourceKind {
  article
  video
  pdf
  external_link
  hotline
}

enum ResourceTopic {
  mental_health
  study_skills
  time_management
  technology
  attendance
  practicum
  general
}

enum TutoringStatus {
  requested
  matched
  in_progress
  completed
  cancelled
}

enum TutoringSessionStatus {
  scheduled
  completed
  no_show
  cancelled
}

enum StudyGroupRole {
  leader
  member
}

enum BookableResourceKind {
  study_room
  equipment
  library
  lab
}

enum BookingStatus {
  reserved
  confirmed
  cancelled
  completed
  no_show
}

enum CourseEnrollmentStatus {
  prospective
  enrolled
  completed
  dropped
  failed
}

enum TranscriptRequestStatus {
  draft
  pending_signature
  in_progress
  delivered
  cancelled
}

enum SentimentLabel {
  positive
  neutral
  negative
  distressed
}

// ----------------------------------------------------------------------------
// Org / tenancy
// ----------------------------------------------------------------------------

model Entity {
  id          String   @id @default(uuid()) @db.Uuid
  external_id String   @unique
  name        String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  campuses Campus[]
  programs Program[]
  students Student[]
}

model Campus {
  id          String   @id @default(uuid()) @db.Uuid
  external_id String   @unique
  name        String
  city        String
  entity_id   String   @db.Uuid
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  entity   Entity    @relation(fields: [entity_id], references: [id])
  students Student[]
  programs Program[]

  @@index([entity_id])
}

model Program {
  id          String   @id @default(uuid()) @db.Uuid
  external_id String   @unique
  name        String
  campus_id   String   @db.Uuid
  entity_id   String   @db.Uuid
  passing_grade Int    @default(70)
  attendance_threshold Int @default(80)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  campus   Campus    @relation(fields: [campus_id], references: [id])
  entity   Entity    @relation(fields: [entity_id], references: [id])
  students Student[]

  @@index([campus_id])
}

// ----------------------------------------------------------------------------
// Identity & RBAC
// ----------------------------------------------------------------------------

model User {
  id                  String    @id @default(uuid()) @db.Uuid
  email               String    @unique
  password_hash       String
  first_name          String
  last_name           String
  role                UserRole
  campus_ids          String[]  @db.Uuid
  program_ids         String[]  @db.Uuid
  entity_ids          String[]  @db.Uuid
  is_active           Boolean   @default(true)
  last_login_at       DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  deleted_at          DateTime?

  // For role=student: link to Student aggregate.
  student_id          String?   @unique @db.Uuid
  student             Student?  @relation("StudentAuth", fields: [student_id], references: [id], onDelete: Cascade)

  // For role=tutor (or any user willing to tutor): subjects they can teach.
  tutoring_subjects   String[]  @default([])
  is_peer_tutor       Boolean   @default(false)

  // Counseling-specific staff guard.
  is_counselor        Boolean   @default(false)

  refresh_tokens               RefreshToken[]
  audit_log_entries            AuditLog[]
  cases_assigned               Case[]            @relation("CaseAssignee")
  interventions_owned          Intervention[]    @relation("InterventionOwner")
  tasks_owned                  Task[]            @relation("TaskOwner")
  students_as_pc               Student[]         @relation("CoordinatorAssignment")
  students_as_rep              Student[]         @relation("RepAssignment")

  messages_sent                Message[]         @relation("MessageSender")
  appointments_as_staff        Appointment[]    @relation("AppointmentStaff")
  staff_availability           StaffAvailability[]
  documents_uploaded           StudentDocument[] @relation("DocumentUploader")
  tutoring_requests_matched    TutoringRequest[] @relation("TutoringMatched")
  tutoring_sessions_as_tutor   TutoringSession[] @relation("TutoringTutor")
  study_groups_created         StudyGroup[]      @relation("StudyGroupCreator")
  workload_snapshots           StaffWorkloadSnapshot[]
}

model RefreshToken {
  id            String   @id @default(uuid()) @db.Uuid
  user_id       String   @db.Uuid
  token_hash    String   @unique
  expires_at    DateTime
  revoked_at    DateTime?
  created_at    DateTime @default(now())
  user_agent    String?
  ip_address    String?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

// ----------------------------------------------------------------------------
// Student aggregate
// ----------------------------------------------------------------------------

model Student {
  id                                String        @id @default(uuid()) @db.Uuid
  student_external_id               String        @unique
  sis_source                        SisSource
  first_name                        String
  last_name                         String
  email                             String
  phone                             String?
  dob                               DateTime      @db.Date
  program_id                        String        @db.Uuid
  campus_id                         String        @db.Uuid
  entity_id                         String        @db.Uuid
  intake_date                       DateTime      @db.Date
  expected_graduation_date          DateTime?     @db.Date
  practicum_start_date              DateTime?     @db.Date
  status                            StudentStatus @default(start)
  workflows_paused                  Boolean       @default(false)
  assigned_program_coordinator_id   String?       @db.Uuid
  assigned_student_services_rep_id  String?       @db.Uuid

  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  // relations
  program  Program @relation(fields: [program_id], references: [id])
  campus   Campus  @relation(fields: [campus_id], references: [id])
  entity   Entity  @relation(fields: [entity_id], references: [id])
  coordinator User? @relation("CoordinatorAssignment", fields: [assigned_program_coordinator_id], references: [id])
  rep         User? @relation("RepAssignment",         fields: [assigned_student_services_rep_id],  references: [id])

  flags                       StudentFlags?
  user                        User?                     @relation("StudentAuth")
  orientation_records         OrientationRecord[]
  welcome_communications      WelcomeCommunication[]
  moodle_enrollment_status    MoodleEnrollmentStatus?
  post_orientation_surveys    PostOrientationSurvey[]
  connect_room_assignments    ConnectRoomAssignment[]
  student_leader_assignments  StudentLeaderAssignment[]
  event_participation         EventParticipation[]
  newsletter_deliveries       NewsletterDelivery[]
  attendance_records          AttendanceRecord[]
  grade_records               GradeRecord[]
  withdrawal_records          WithdrawalRecord[]
  risk_assessments            RiskAssessment[]
  early_alerts                EarlyAlert[]
  cases                       Case[]
  interventions               Intervention[]
  class_audits                ClassAudit[]
  accommodation_requests      AccommodationRequest[]
  reentry_plans               ReentryPlan[]
  practicum_placements        PracticumPlacement[]
  timeline_progress           StudentTimelineProgress[]
  communications              Communication[]

  message_threads             MessageThread[]
  appointments                Appointment[]
  documents                   StudentDocument[]
  wellness_checkins           WellnessCheckin[]
  tutoring_requests           TutoringRequest[]
  study_group_memberships     StudyGroupMember[]
  resource_bookings           ResourceBooking[]
  course_enrollments          CourseEnrollment[]
  transcript_requests         TranscriptRequest[]

  @@unique([campus_id, email])
  @@index([campus_id, status])
  @@index([program_id])
  @@index([entity_id])
}

model StudentFlags {
  student_id                String   @id @db.Uuid
  at_risk_flag              Boolean  @default(false)
  re_entry_flag             Boolean  @default(false)
  practicum_ready_flag      Boolean  @default(false)
  completed_hours_flag      Boolean  @default(false)
  orientation_complete_flag Boolean  @default(false)
  risk_score                Int      @default(0)
  engagement_score          Int      @default(0)
  engagement_tier           String   @default("low")
  last_recomputed_at        DateTime @default(now())

  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------------------------------
// Universal: Audit, Events, Communications, Tasks
// ----------------------------------------------------------------------------

model AuditLog {
  id              String   @id @default(uuid()) @db.Uuid
  actor_id        String?  @db.Uuid
  actor_label     String?
  action          String
  resource_type   String
  resource_id     String?
  before          Json?
  after           Json?
  outcome         String   @default("ok")
  campus_id       String?  @db.Uuid
  correlation_id  String?
  occurred_at     DateTime @default(now())

  actor User? @relation(fields: [actor_id], references: [id])

  @@index([actor_id])
  @@index([resource_type, resource_id])
  @@index([occurred_at])
}

model EventStore {
  event_id        String   @id @db.Uuid
  event_type      String
  student_id      String?  @db.Uuid
  actor_id        String?
  payload         Json
  occurred_at     DateTime @default(now())
  correlation_id  String

  @@index([event_type])
  @@index([student_id])
  @@index([occurred_at])
}

model Communication {
  id              String                 @id @default(uuid()) @db.Uuid
  student_id      String?                @db.Uuid
  actor_id        String?                @db.Uuid
  direction       CommunicationDirection
  channel         CommunicationChannel
  from_address    String
  to_address      String
  subject         String?
  body_or_summary String
  external_id     String?
  attachments_url String?
  occurred_at     DateTime               @default(now())

  student Student? @relation(fields: [student_id], references: [id], onDelete: SetNull)

  @@index([student_id])
  @@index([channel])
  @@index([occurred_at])
}

model Task {
  id              String       @id @default(uuid()) @db.Uuid
  title           String
  description     String?
  source_event_id String?      @db.Uuid
  student_id      String?      @db.Uuid
  owner_user_id   String?      @db.Uuid
  campus_id       String?      @db.Uuid
  priority        TaskPriority @default(normal)
  status          TaskStatus   @default(open)
  due_at          DateTime?
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  closed_at       DateTime?

  owner User? @relation("TaskOwner", fields: [owner_user_id], references: [id])

  @@index([owner_user_id, status])
  @@index([student_id])
}

// ----------------------------------------------------------------------------
// Module 1 — Intake & Onboarding
// ----------------------------------------------------------------------------

model OrientationRecord {
  id            String    @id @default(uuid()) @db.Uuid
  student_id    String    @db.Uuid
  scheduled_at  DateTime
  attended_at   DateTime?
  missed        Boolean   @default(false)
  notes         String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([student_id])
}

model WelcomeCommunication {
  id           String   @id @default(uuid()) @db.Uuid
  student_id   String   @db.Uuid
  template     String
  channel      CommunicationChannel
  sent_at      DateTime @default(now())

  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([student_id])
}

model MoodleEnrollmentStatus {
  student_id    String    @id @db.Uuid
  enrolled      Boolean   @default(false)
  enrolled_at   DateTime?
  course_ids    String[]
  last_activity DateTime?

  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

model PostOrientationSurvey {
  id              String    @id @default(uuid()) @db.Uuid
  student_id      String    @db.Uuid
  sent_at         DateTime  @default(now())
  submitted_at    DateTime?
  reminders_sent  Int       @default(0)
  responses       Json?
  nps_score       Int?

  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([student_id])
}

// ----------------------------------------------------------------------------
// Module 2 — Engagement
// ----------------------------------------------------------------------------

model ConnectRoom {
  id          String   @id @default(uuid()) @db.Uuid
  campus_id   String   @db.Uuid
  name        String
  topic       String?
  created_at  DateTime @default(now())

  assignments ConnectRoomAssignment[]
}

model ConnectRoomAssignment {
  id              String   @id @default(uuid()) @db.Uuid
  student_id      String   @db.Uuid
  connect_room_id String   @db.Uuid
  assigned_at     DateTime @default(now())
  active          Boolean  @default(true)

  student      Student     @relation(fields: [student_id], references: [id], onDelete: Cascade)
  connect_room ConnectRoom @relation(fields: [connect_room_id], references: [id], onDelete: Cascade)

  @@index([student_id])
}

model StudentLeaderAssignment {
  id            String   @id @default(uuid()) @db.Uuid
  student_id    String   @db.Uuid
  leader_user_id String  @db.Uuid
  assigned_at   DateTime @default(now())

  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([student_id, leader_user_id])
}

model EventParticipation {
  id            String   @id @default(uuid()) @db.Uuid
  student_id    String   @db.Uuid
  event_kind    String
  event_ref     String?
  attended_at   DateTime @default(now())

  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([student_id])
}

model NewsletterDelivery {
  id              String           @id @default(uuid()) @db.Uuid
  student_id      String           @db.Uuid
  newsletter_id   String
  subject         String
  status          NewsletterStatus @default(scheduled)
  sent_at         DateTime?
  opened_at       DateTime?
  open_count      Int              @default(0)

  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([student_id])
  @@index([newsletter_id])
}

model EngagementScoreConfig {
  id                              String   @id @default(uuid()) @db.Uuid
  weight_event_attendance         Float    @default(0.30)
  weight_newsletter_open          Float    @default(0.25)
  weight_connect_room             Float    @default(0.25)
  weight_outreach_response        Float    @default(0.20)
  threshold_high                  Int      @default(70)
  threshold_medium                Int      @default(40)
  active                          Boolean  @default(true)
  effective_at                    DateTime @default(now())
}

model StudentTimelineProgress {
  id           String    @id @default(uuid()) @db.Uuid
  student_id   String    @db.Uuid
  step_key     String
  scheduled_at DateTime
  completed_at DateTime?

  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([student_id, step_key])
  @@index([scheduled_at])
}

// ----------------------------------------------------------------------------
// Module 3 — Early Alert & Risk
// ----------------------------------------------------------------------------

model RiskRuleConfig {
  id                                   String   @id @default(uuid()) @db.Uuid
  weight_grade_below_threshold         Int      @default(40)
  weight_missing_grades_overdue        Int      @default(20)
  weight_attendance_below_threshold    Int      @default(25)
  weight_no_attendance_recorded        Int      @default(15)
  weight_esl_below_threshold           Int      @default(10)
  weight_age_gte_65                    Int      @default(10)
  weight_withdrawal_initiated          Int      @default(50)
  flag_threshold                       Int      @default(50)
  active                               Boolean  @default(true)
  effective_at                         DateTime @default(now())
}

model AttendanceRecord {
  id          String           @id @default(uuid()) @db.Uuid
  student_id  String           @db.Uuid
  source      AttendanceSource
  session_id  String
  occurred_at DateTime
  present     Boolean
  raw         Json?

  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([student_id, occurred_at])
}

model GradeRecord {
  id              String   @id @default(uuid()) @db.Uuid
  student_id      String   @db.Uuid
  course_external_id String
  assessment_id   String
  value           Float
  threshold       Float
  recorded_at     DateTime
  raw             Json?

  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([student_id, recorded_at])
}

model WithdrawalRecord {
  id              String   @id @default(uuid()) @db.Uuid
  student_id      String   @db.Uuid
  reason          String
  requested_by    String?  @db.Uuid
  initiated_at    DateTime @default(now())
  confirmed_at    DateTime?
  effective_date  DateTime?

  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([student_id])
}

model RiskAssessment {
  id            String   @id @default(uuid()) @db.Uuid
  student_id    String   @db.Uuid
  risk_score    Int
  flagged       Boolean
  top_factors   String[]
  rule_versions String[]
  computed_at   DateTime @default(now())

  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([student_id, computed_at])
}

model EarlyAlert {
  id          String   @id @default(uuid()) @db.Uuid
  student_id  String   @db.Uuid
  reason      String
  severity    String
  raised_at   DateTime @default(now())
  cleared_at  DateTime?

  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([student_id])
}

model Case {
  id              String     @id @default(uuid()) @db.Uuid
  student_id      String     @db.Uuid
  reason          String
  kind            String     @default("at_risk") // at_risk | wellness | tutoring | other
  confidential    Boolean    @default(false)
  status          CaseStatus @default(open)
  assignee_id     String?    @db.Uuid
  opened_at       DateTime   @default(now())
  closed_at       DateTime?
  resolution      String?
  last_action_at  DateTime?
  escalated_at    DateTime?

  student   Student @relation(fields: [student_id], references: [id], onDelete: Cascade)
  assignee  User?   @relation("CaseAssignee", fields: [assignee_id], references: [id])

  interventions Intervention[]

  @@index([assignee_id, status])
  @@index([student_id])
  @@index([kind, status])
}

// ----------------------------------------------------------------------------
// Module 4 — Academic Support
// ----------------------------------------------------------------------------

model InterventionPlaybook {
  id            String           @id @default(uuid()) @db.Uuid
  type          InterventionType
  name          String
  body_md       String
  active        Boolean          @default(true)
  created_at    DateTime         @default(now())
  updated_at    DateTime         @updatedAt
}

model Intervention {
  id            String             @id @default(uuid()) @db.Uuid
  student_id    String             @db.Uuid
  case_id       String?            @db.Uuid
  type          InterventionType
  playbook_id   String?            @db.Uuid
  owner_id      String?            @db.Uuid
  status        InterventionStatus @default(assigned)
  outcome       String?
  assigned_at   DateTime           @default(now())
  completed_at  DateTime?

  student  Student @relation(fields: [student_id], references: [id], onDelete: Cascade)
  case     Case?   @relation(fields: [case_id], references: [id], onDelete: SetNull)
  owner    User?   @relation("InterventionOwner", fields: [owner_id], references: [id])

  @@index([student_id])
  @@index([owner_id, status])
}

model ClassAudit {
  id            String    @id @default(uuid()) @db.Uuid
  student_id    String?   @db.Uuid
  class_ref     String
  issues        String[]
  resolution    String?
  resolved_by   String?   @db.Uuid
  due_at        DateTime?
  logged_at     DateTime  @default(now())
  resolved_at   DateTime?

  student Student? @relation(fields: [student_id], references: [id], onDelete: SetNull)

  @@index([class_ref])
}

model AccommodationRequest {
  id            String              @id @default(uuid()) @db.Uuid
  student_id    String              @db.Uuid
  type          String
  description   String
  status        AccommodationStatus @default(requested)
  requested_at  DateTime            @default(now())
  approved_at   DateTime?
  approved_by   String?             @db.Uuid
  pandadoc_ref  String?

  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)
}

model ReentryPlan {
  id              String         @id @default(uuid()) @db.Uuid
  student_id      String         @db.Uuid
  status          ReentryStatus  @default(active)
  initiated_at    DateTime       @default(now())
  completed_at    DateTime?
  weeks_total     Int            @default(4)

  student Student              @relation(fields: [student_id], references: [id], onDelete: Cascade)
  checks  ReentryWeeklyCheck[]
}

model ReentryWeeklyCheck {
  id              String   @id @default(uuid()) @db.Uuid
  reentry_plan_id String   @db.Uuid
  week_n          Int
  scheduled_at    DateTime
  completed_at    DateTime?
  summary         String?

  plan ReentryPlan @relation(fields: [reentry_plan_id], references: [id], onDelete: Cascade)

  @@unique([reentry_plan_id, week_n])
}

// ----------------------------------------------------------------------------
// Module 5 — Practicum
// ----------------------------------------------------------------------------

model PracticumPlacement {
  id           String          @id @default(uuid()) @db.Uuid
  student_id   String          @db.Uuid
  site_name    String
  supervisor_id String?        @db.Uuid
  start_date   DateTime
  end_date     DateTime?
  status       PracticumStatus @default(pending)
  hours_target Int             @default(0)

  student     Student              @relation(fields: [student_id], references: [id], onDelete: Cascade)
  supervisor  PracticumSupervisor? @relation(fields: [supervisor_id], references: [id])
  hours_logs  PracticumHoursLog[]
  evaluations PracticumEvaluation[]

  @@index([student_id])
}

model PracticumSupervisor {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  email         String
  phone         String?
  organization  String
  created_at    DateTime @default(now())

  placements PracticumPlacement[]
}

model PracticumHoursLog {
  id            String   @id @default(uuid()) @db.Uuid
  placement_id  String   @db.Uuid
  occurred_on   DateTime @db.Date
  hours         Float
  notes         String?
  approved      Boolean  @default(false)

  placement PracticumPlacement @relation(fields: [placement_id], references: [id], onDelete: Cascade)
}

model PracticumEvaluation {
  id            String   @id @default(uuid()) @db.Uuid
  placement_id  String   @db.Uuid
  evaluator     String
  score         Int
  comments      String?
  evaluated_at  DateTime @default(now())

  placement PracticumPlacement @relation(fields: [placement_id], references: [id], onDelete: Cascade)
}

// ----------------------------------------------------------------------------
// Student-facing portal additions
// ----------------------------------------------------------------------------

model MessageThread {
  id          String              @id @default(uuid()) @db.Uuid
  student_id  String              @db.Uuid
  subject     String
  status      MessageThreadStatus @default(open)
  created_at  DateTime            @default(now())
  updated_at  DateTime            @updatedAt
  last_message_at DateTime?
  confidential Boolean            @default(false)

  student   Student   @relation(fields: [student_id], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([student_id, status])
  @@index([last_message_at])
}

model Message {
  id            String   @id @default(uuid()) @db.Uuid
  thread_id     String   @db.Uuid
  sender_user_id String  @db.Uuid
  body          String
  body_html     String?
  attachments   Json?
  read_by       Json     @default("[]")
  created_at    DateTime @default(now())
  edited_at     DateTime?
  sentiment_label SentimentLabel?
  sentiment_score Float?

  thread MessageThread @relation(fields: [thread_id], references: [id], onDelete: Cascade)
  sender User          @relation("MessageSender", fields: [sender_user_id], references: [id])

  @@index([thread_id, created_at])
}

model StaffAvailability {
  id            String   @id @default(uuid()) @db.Uuid
  user_id       String   @db.Uuid
  day_of_week   Int      // 0 (Sun) - 6 (Sat) per JS Date.getDay()
  start_minute  Int      // minutes from midnight, local TZ
  end_minute    Int
  slot_minutes  Int      @default(30)
  appointment_kinds AppointmentKind[]
  active        Boolean  @default(true)
  effective_from DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, day_of_week])
}

model Appointment {
  id              String              @id @default(uuid()) @db.Uuid
  student_id      String              @db.Uuid
  staff_user_id   String              @db.Uuid
  kind            AppointmentKind
  status          AppointmentStatus   @default(requested)
  location        AppointmentLocation @default(video)
  location_detail String?
  scheduled_at    DateTime
  duration_minutes Int                @default(30)
  notes_student   String?
  notes_staff     String?
  case_id         String?             @db.Uuid
  google_event_id String?
  created_at      DateTime            @default(now())
  updated_at      DateTime            @updatedAt
  cancelled_at    DateTime?
  cancelled_reason String?

  student   Student @relation(fields: [student_id], references: [id], onDelete: Cascade)
  staff     User    @relation("AppointmentStaff", fields: [staff_user_id], references: [id])

  @@index([student_id])
  @@index([staff_user_id, scheduled_at])
}

model StudentDocument {
  id              String         @id @default(uuid()) @db.Uuid
  student_id      String         @db.Uuid
  uploaded_by_id  String         @db.Uuid
  kind            DocumentKind
  filename        String
  storage_url     String
  mime_type       String
  size_bytes      Int
  status          DocumentStatus @default(uploaded)
  reviewer_notes  String?
  uploaded_at     DateTime       @default(now())
  reviewed_at     DateTime?
  expires_at      DateTime?

  student     Student @relation(fields: [student_id], references: [id], onDelete: Cascade)
  uploaded_by User    @relation("DocumentUploader", fields: [uploaded_by_id], references: [id])

  @@index([student_id, kind])
}

// ----------------------------------------------------------------------------
// Wellness
// ----------------------------------------------------------------------------

model WellnessCheckin {
  id              String           @id @default(uuid()) @db.Uuid
  student_id      String           @db.Uuid
  phq2_q1         Int              // 0-3 — "Little interest or pleasure in doing things"
  phq2_q2         Int              // 0-3 — "Feeling down, depressed, or hopeless"
  phq2_total      Int
  stress_score    Int              // 0-10 self-reported
  energy_score    Int?             // 0-10
  sleep_hours     Float?
  free_text       String?
  risk_tier       WellnessRiskTier
  ai_flagged      Boolean          @default(false)
  ai_summary      String?
  occurred_at     DateTime         @default(now())

  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([student_id, occurred_at])
  @@index([risk_tier])
}

model AnonymousReport {
  id          String                  @id @default(uuid()) @db.Uuid
  // hash_token lets the reporter check status without revealing identity.
  hash_token  String                  @unique
  category    AnonymousReportCategory
  campus_id   String?                 @db.Uuid
  body        String
  contact_optional String?
  status      AnonymousReportStatus   @default(new)
  triaged_by  String?                 @db.Uuid
  notes       String?
  created_at  DateTime                @default(now())
  resolved_at DateTime?

  @@index([status])
  @@index([category])
}

model Resource {
  id          String        @id @default(uuid()) @db.Uuid
  kind        ResourceKind
  topic       ResourceTopic
  title       String
  body_md     String?
  url         String?
  campus_scope String[]     @db.Uuid    // empty = all campuses
  tags        String[]
  language    String        @default("en")
  is_crisis   Boolean       @default(false)
  published_at DateTime     @default(now())

  @@index([topic])
  @@index([kind])
}

// ----------------------------------------------------------------------------
// Tutoring
// ----------------------------------------------------------------------------

model TutoringRequest {
  id            String         @id @default(uuid()) @db.Uuid
  student_id    String         @db.Uuid
  subject       String
  topic         String?
  urgency       String         @default("normal")  // low | normal | high
  preferred_format String      @default("any")      // in_person | video | any
  notes         String?
  status        TutoringStatus @default(requested)
  matched_user_id String?      @db.Uuid
  created_at    DateTime       @default(now())
  matched_at    DateTime?
  closed_at     DateTime?

  student      Student @relation(fields: [student_id], references: [id], onDelete: Cascade)
  matched_user User?   @relation("TutoringMatched", fields: [matched_user_id], references: [id])
  sessions     TutoringSession[]

  @@index([status])
  @@index([student_id])
}

model TutoringSession {
  id              String                  @id @default(uuid()) @db.Uuid
  request_id      String                  @db.Uuid
  tutor_user_id   String                  @db.Uuid
  scheduled_at    DateTime
  duration_minutes Int                    @default(45)
  status          TutoringSessionStatus   @default(scheduled)
  notes           String?
  hours_credited  Float                   @default(0)

  request TutoringRequest @relation(fields: [request_id], references: [id], onDelete: Cascade)
  tutor   User            @relation("TutoringTutor", fields: [tutor_user_id], references: [id])

  @@index([request_id])
  @@index([tutor_user_id, scheduled_at])
}

// ----------------------------------------------------------------------------
// Study groups
// ----------------------------------------------------------------------------

model StudyGroup {
  id              String   @id @default(uuid()) @db.Uuid
  campus_id       String   @db.Uuid
  course_external_id String?
  name            String
  description     String?
  max_members     Int      @default(8)
  meeting_pattern String?
  created_by_user_id String? @db.Uuid
  created_at      DateTime @default(now())
  archived_at     DateTime?

  creator User?              @relation("StudyGroupCreator", fields: [created_by_user_id], references: [id])
  members StudyGroupMember[]

  @@index([campus_id])
  @@index([course_external_id])
}

model StudyGroupMember {
  id           String         @id @default(uuid()) @db.Uuid
  group_id     String         @db.Uuid
  student_id   String         @db.Uuid
  role         StudyGroupRole @default(member)
  joined_at    DateTime       @default(now())
  left_at      DateTime?

  group   StudyGroup @relation(fields: [group_id], references: [id], onDelete: Cascade)
  student Student    @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([group_id, student_id])
}

// ----------------------------------------------------------------------------
// Bookable resources (study rooms / equipment / lab time)
// ----------------------------------------------------------------------------

model BookableResource {
  id            String              @id @default(uuid()) @db.Uuid
  campus_id     String              @db.Uuid
  kind          BookableResourceKind
  name          String
  location      String?
  capacity      Int                 @default(1)
  slot_minutes  Int                 @default(60)
  open_minute   Int                 @default(420)   // 7:00 local
  close_minute  Int                 @default(1260)  // 21:00 local
  active        Boolean             @default(true)

  bookings ResourceBooking[]

  @@index([campus_id, kind])
}

model ResourceBooking {
  id          String        @id @default(uuid()) @db.Uuid
  resource_id String        @db.Uuid
  student_id  String        @db.Uuid
  starts_at   DateTime
  ends_at     DateTime
  status      BookingStatus @default(reserved)
  created_at  DateTime      @default(now())
  cancelled_at DateTime?

  resource BookableResource @relation(fields: [resource_id], references: [id], onDelete: Cascade)
  student  Student          @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([resource_id, starts_at])
  @@index([student_id])
}

// ----------------------------------------------------------------------------
// Course catalog
// ----------------------------------------------------------------------------

model Course {
  id            String   @id @default(uuid()) @db.Uuid
  external_id   String   @unique
  code          String
  name          String
  description   String?
  credits       Float    @default(0)
  campus_id     String   @db.Uuid
  program_id    String?  @db.Uuid
  active        Boolean  @default(true)
  created_at    DateTime @default(now())

  prerequisites CoursePrerequisite[] @relation("CourseRequires")
  required_by   CoursePrerequisite[] @relation("CourseRequiresOf")
  enrollments   CourseEnrollment[]

  @@index([campus_id, active])
}

model CoursePrerequisite {
  course_id           String @db.Uuid
  requires_course_id  String @db.Uuid

  course           Course @relation("CourseRequires",   fields: [course_id], references: [id], onDelete: Cascade)
  requires_course  Course @relation("CourseRequiresOf", fields: [requires_course_id], references: [id], onDelete: Cascade)

  @@id([course_id, requires_course_id])
}

model CourseEnrollment {
  id          String                  @id @default(uuid()) @db.Uuid
  course_id   String                  @db.Uuid
  student_id  String                  @db.Uuid
  status      CourseEnrollmentStatus  @default(prospective)
  term        String?
  enrolled_at DateTime                @default(now())
  ended_at    DateTime?

  course  Course  @relation(fields: [course_id], references: [id], onDelete: Cascade)
  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([course_id, student_id, term])
  @@index([student_id])
}

// ----------------------------------------------------------------------------
// Transcript / verification requests (uses PandaDoc adapter)
// ----------------------------------------------------------------------------

model TranscriptRequest {
  id              String                  @id @default(uuid()) @db.Uuid
  student_id      String                  @db.Uuid
  recipient_name  String
  recipient_email String
  notes           String?
  status          TranscriptRequestStatus @default(draft)
  pandadoc_ref    String?
  requested_at    DateTime                @default(now())
  delivered_at    DateTime?

  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@index([student_id])
  @@index([status])
}

// ----------------------------------------------------------------------------
// Automation: workload balancer + ML training exports
// ----------------------------------------------------------------------------

model StaffWorkloadSnapshot {
  id                    String   @id @default(uuid()) @db.Uuid
  user_id               String   @db.Uuid
  captured_at           DateTime @default(now())
  open_cases            Int
  open_tasks            Int
  open_interventions    Int
  appointments_next_7d  Int
  avg_response_minutes  Float?
  burnout_score         Int      @default(0)   // 0-100, higher = more loaded
  flagged               Boolean  @default(false)
  notes                 String?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, captured_at])
}

model MlTrainingExport {
  id          String   @id @default(uuid()) @db.Uuid
  generated_at DateTime @default(now())
  row_count   Int
  storage_url String
  notes       String?
}
