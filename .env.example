# --- Core ---------------------------------------------------------------
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
TZ=America/Edmonton

# --- Database (Postgres) ------------------------------------------------
DATABASE_URL=postgresql://mcg:mcg@localhost:5432/mcg_student_services?schema=public

# --- Cache / Queue (Redis + BullMQ) -------------------------------------
REDIS_URL=redis://localhost:6379

# --- Auth ---------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
BCRYPT_COST=12

# --- Frontend -----------------------------------------------------------
VITE_API_BASE_URL=http://localhost:3001

# --- Adapter selection (http | mock) ------------------------------------
SIS_ADAPTER=mock                   # campuslogin | salesforce | mock
MOODLE_ADAPTER=mock                # http | mock
BBB_ADAPTER=mock                   # http | mock
TWILIO_ADAPTER=mock                # http | mock
JUSTCALL_ADAPTER=mock              # http | mock
PANDADOC_ADAPTER=mock              # http | mock
GOOGLE_ADAPTER=mock                # http | mock
FAL_ADAPTER=mock                   # http | mock
CLAUDE_ADAPTER=mock                # http | mock

# --- CampusLogin --------------------------------------------------------
CAMPUSLOGIN_BASE_URL=
CAMPUSLOGIN_API_KEY=
CAMPUSLOGIN_POLL_INTERVAL_MIN=15

# --- Salesforce (skeleton — Phase 6) ------------------------------------
SALESFORCE_BASE_URL=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=

# --- Moodle -------------------------------------------------------------
MOODLE_BASE_URL=
MOODLE_TOKEN=

# --- BigBlueButton ------------------------------------------------------
BBB_BASE_URL=
BBB_SHARED_SECRET=

# --- Twilio (SMS) -------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- JustCall (CTI) -----------------------------------------------------
JUSTCALL_API_KEY=
JUSTCALL_API_SECRET=

# --- PandaDoc -----------------------------------------------------------
PANDADOC_API_KEY=

# --- Google Workspace ---------------------------------------------------
GOOGLE_OIDC_CLIENT_ID=
GOOGLE_OIDC_CLIENT_SECRET=
GOOGLE_SERVICE_ACCOUNT_JSON=

# --- FAL.ai -------------------------------------------------------------
FAL_API_KEY=

# --- Claude API ---------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_CACHE_TTL_HOURS=24

# --- SMTP (Nodemailer for transactional email) --------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="MCG Student Services <noreply@mcg.example>"
